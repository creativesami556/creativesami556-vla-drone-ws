{
  "name": "VLA Drone Workspace",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/python:1": {}
  },
  "runArgs": ["--network=host", "--privileged"],
  "containerEnv": {
    "DISPLAY": ":1",
    "ROS_DOMAIN_ID": "0"
  },
  "postCreateCommand": "bash /workspaces/vla-drone-ws/.devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-vscode.cpptools",
        "twxs.cmake"
      ]
    }
  },
  "forwardPorts": [6080, 5000, 4040],
  "portsAttributes": {
    "6080": {"label": "Gazebo Display"},
    "5000": {"label": "VLA Flask API"},
    "4040": {"label": "ngrok Dashboard"}
  }
}
